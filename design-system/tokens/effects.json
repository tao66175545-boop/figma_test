{
  "$schema": "https://design-tokens.org/schema.json",
  "$description": "设计系统效果令牌 - AI可读格式",
  "effects": {
    "shadow": {
      "$type": "shadow",
      "$description": "阴影效果",
      "none": {
        "$value": "none",
        "$description": "无阴影"
      },
      "xs": {
        "$value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
        "$description": "超小阴影，用于微妙的层级感"
      },
      "sm": {
        "$value": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1)",
        "$description": "小阴影，用于卡片悬浮"
      },
      "md": {
        "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
        "$description": "中等阴影，用于下拉菜单"
      },
      "lg": {
        "$value": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
        "$description": "大阴影，用于模态框"
      },
      "xl": {
        "$value": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)",
        "$description": "超大阴影，用于悬浮面板"
      },
      "2xl": {
        "$value": "0 25px 50px -12px rgba(0, 0, 0, 0.25)",
        "$description": "特大阴影，用于弹出层"
      },
      "inner": {
        "$value": "inset 0 2px 4px 0 rgba(0, 0, 0, 0.05)",
        "$description": "内阴影，用于输入框等凹陷效果"
      }
    },
    "borderRadius": {
      "$type": "dimension",
      "$description": "圆角半径",
      "none": { "$value": "0", "$description": "无圆角" },
      "sm": { "$value": "2px", "$description": "小圆角" },
      "md": { "$value": "4px", "$description": "中等圆角" },
      "lg": { "$value": "8px", "$description": "大圆角" },
      "xl": { "$value": "12px", "$description": "超大圆角" },
      "2xl": { "$value": "16px", "$description": "特大圆角" },
      "3xl": { "$value": "24px", "$description": "巨大圆角" },
      "full": { "$value": "9999px", "$description": "完全圆形" }
    },
    "borderWidth": {
      "$type": "dimension",
      "$description": "边框宽度",
      "0": { "$value": "0", "$description": "无边框" },
      "1": { "$value": "1px", "$description": "细边框" },
      "2": { "$value": "2px", "$description": "中等边框" },
      "4": { "$value": "4px", "$description": "粗边框" },
      "8": { "$value": "8px", "$description": "特粗边框" }
    },
    "opacity": {
      "$type": "number",
      "$description": "透明度",
      "0": { "$value": 0, "$description": "完全透明" },
      "5": { "$value": 0.05, "$description": "几乎透明" },
      "10": { "$value": 0.1, "$description": "很透明" },
      "20": { "$value": 0.2, "$description": "较透明" },
      "25": { "$value": 0.25, "$description": "中等透明" },
      "30": { "$value": 0.3, "$description": "稍透明" },
      "40": { "$value": 0.4, "$description": "半透明偏淡" },
      "50": { "$value": 0.5, "$description": "半透明" },
      "60": { "$value": 0.6, "$description": "半透明偏浓" },
      "70": { "$value": 0.7, "$description": "较不透明" },
      "75": { "$value": 0.75, "$description": "中等不透明" },
      "80": { "$value": 0.8, "$description": "稍不透明" },
      "90": { "$value": 0.9, "$description": "几乎不透明" },
      "95": { "$value": 0.95, "$description": "很不透明" },
      "100": { "$value": 1, "$description": "完全不透明" }
    },
    "transition": {
      "$description": "过渡动画",
      "duration": {
        "$type": "duration",
        "fast": { "$value": "150ms", "$description": "快速过渡" },
        "normal": { "$value": "300ms", "$description": "标准过渡" },
        "slow": { "$value": "500ms", "$description": "慢速过渡" }
      },
      "easing": {
        "$type": "cubicBezier",
        "linear": { "$value": "linear", "$description": "线性" },
        "ease": { "$value": "ease", "$description": "标准缓动" },
        "easeIn": { "$value": "ease-in", "$description": "加速" },
        "easeOut": { "$value": "ease-out", "$description": "减速" },
        "easeInOut": { "$value": "ease-in-out", "$description": "先加速后减速" }
      }
    }
  }
}
